# User-specific stuff:
.idea

# Claude Code internal files
.claude/

## File-based project format:
*.iws

# IntelliJ
/out/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Test caches
.pytest_cache/
.coverage
htmlcov/

# logs
*.log*

# databases
*.db

# configs — config.json is local (treat like .env); only the sample is versioned.
# /*.json covers config.json and config.new.json; /config.json.* covers local
# backups like config.json.factory / config.json.bak so a PLEX_TOKEN can never
# be committed. The versioned template is re-included last.
*.cfg
/*.json
/config.json.*
!/config_sample.json

# runtime artifacts written next to the script (logs are covered by *.log* above)
/plans/
/reports/
/quarantine/
dupefinder_plan_*.json
dupefinder_report_*.json
*.dupefinder_meta.json

# generators
*.bat

# Pyenv
**/.python-version

# PyInstaller
build/
dist/
*.manifest
*.spec

# Virtualenv
.Python
[Bb]in
[Ii]nclude
[Ll]ib
[Ll]ib64
[Ll]ocal
[Ss]cripts
pyvenv.cfg
.venv
pip-selfcheck.json

# Venv
venv/
